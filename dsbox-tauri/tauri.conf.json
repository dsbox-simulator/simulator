{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DsBox",
  "identifier": "com.bsvs.dsbox",
  "build": {
    "frontendDist": "../webapp/dist",
    "beforeBuildCommand": "npm --prefix ../webapp run build -- --release",
    "beforeDevCommand": "npm --prefix ../webapp run serve",
    "devUrl": "http://localhost:8000",
    "additionalWatchFolders": ["../webapp"]
  },
  "app": {
    "windows": [
      {
        "title": "DsBox",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {}
    }
  }
}
